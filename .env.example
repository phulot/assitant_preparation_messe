# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000

# ──────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────
POSTGRES_USER=chants
POSTGRES_PASSWORD=chants_secret
POSTGRES_DB=chants_liturgiques
DB_PORT=5432
DATABASE_URL=postgresql://chants:chants_secret@db:5432/chants_liturgiques?schema=public

# ──────────────────────────────────────────────
# MinIO (S3-compatible storage)
# ──────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ──────────────────────────────────────────────
# Ollama (local LLM)
# ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_PORT=11434

# ──────────────────────────────────────────────
# Redis (optional, for caching)
# ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# ──────────────────────────────────────────────
# NextAuth.js
# ──────────────────────────────────────────────
NEXTAUTH_SECRET=change-me-to-a-random-secret
NEXTAUTH_URL=http://localhost:3000
